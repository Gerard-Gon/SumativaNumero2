{
  "family": "techstore-api-task",
  "taskRoleArn": "arn:aws:iam::994995081324:role/LabRole",
  "executionRoleArn": "arn:aws:iam::994995081324:role/LabRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "techstore-api",
      "image": "994995081324.dkr.ecr.us-east-1.amazonaws.com/techstore-api:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "techstore-api-8080-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "SPRING_DATASOURCE_URL",
          "value": "jdbc:postgresql://techstore-db.ci0depbyvluy.us-east-1.rds.amazonaws.com:5432/techstore"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "value": "techadmin"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "value": "admin123"
        },
        {
          "name": "SPRING_JPA_HIBERNATE_DDL_AUTO",
          "value": "update"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/techstore-api-task",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": []
    }
  ],
  "volumes": [],
  "placementConstraints": []
}